generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  Authenticator Authenticator[]
  guesses         Guess[]
  bets            Bet[]
  chipBalance     ChipBalance?
  userCards       UserCard[]
  connectionScores ConnectionScore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Match {
  id         String  @id @default(cuid())
  round      String  // "group" | "roundOf32" | "roundOf16" | "quarterFinal" | "semiFinal" | "final"
  groupId    String? // "A"-"L" for group stage, null for knockout
  matchOrder Int     // ordering within the round
  teamAId    String? // null for knockout until bracket resolves
  teamBId    String?
  teamAName  String? // denormalized display name
  teamBName  String?
  scoreA     Int?    // real result (null = not played)
  scoreB     Int?
  isFact     Boolean @default(false)

  guesses Guess[]
  bets     Bet[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guess {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  scoreA    Int
  scoreB    Int
  points    Int?     // calculated when match becomes fact

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId])
}

model CardTemplate {
  id            String   @id @default(cuid())
  name          String
  description   String
  effect        String   // machine-readable key: "double_down" | "hedge" | "lock_in" | "scout" | "insurance" | "boost"
  rarity        String   // "common" | "uncommon" | "rare"
  cooldownHours Int      @default(0)
  multiplier    Float?   // optional numeric modifier

  userCards UserCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserCard {
  id              String       @id @default(cuid())
  userId          String
  cardTemplateId  String
  quantity        Int          @default(1)
  lastUsedAt      DateTime?

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  card   CardTemplate @relation(fields: [cardTemplateId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cardTemplateId])
}

model ChipBalance {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Int      @default(500)
  lifetimeEarnings Int  @default(0)
  dailyStreak   Int      @default(0)
  lastDailyAt   DateTime?
  rankingAdjustment Int  @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Bet {
  id          String   @id @default(cuid())
  userId      String
  matchId     String
  scoreA      Int
  scoreB      Int
  wagerAmount Int
  oddsMultiplier Float @default(1.0)
  payout      Int?     // null = not resolved yet
  cardId      String?  // userCard id if a card was used

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, matchId])
}

model ConnectionScore {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  difficulty String  // "easy" | "medium" | "hard" | "expert"
  mode      String   // "daily" | "infinite" | "hardcore" | "timed"
  chainLength Int
  shortestPossible Int
  attempts  Int
  timeSeconds Int
  usedHint  Boolean  @default(false)
  playerA   String   // player name
  playerB   String   // player name

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([score])
}
