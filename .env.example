# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Required for production — set to your deployment URL (Vercel auto-sets this for Pro/Enterprise)
NEXTAUTH_URL="https://fifaworldcup2026.vercel.app"

DATABASE_URL="your_database_url_here"

AUTH_GITHUB_ID="your_github_oauth_app_client_id"
AUTH_GITHUB_SECRET="your_github_oauth_app_client_secret"

AUTH_GOOGLE_ID="your_google_oauth_client_id"
AUTH_GOOGLE_SECRET="your_google_oauth_client_secret"

AUTH_SECRET="a_random_32_byte_hex_string_generate_with_openssl_rand_base64_32"

# Optional — enables AI-powered analysis and chat features (Groq free tier)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY="gsk_your_groq_api_key_here"

# Required for email notifications (Resend free tier: 100 emails/day)
# Get a key at https://resend.com
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="FIFA 2026 <onboarding@resend.dev>"
